{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.com/v1/social-content/news-article.json",
  "title": "News Article",
  "description": "Structured news article for LLM pipelines and media monitoring.",
  "type": "object",
  "properties": {
    "headline": {
      "type": "string",
      "description": "Main headline of the article.",
      "x-tabstack-priority": "required"
    },
    "subheadline": {
      "type": "string",
      "description": "Secondary headline or deck of the article.",
      "x-tabstack-priority": "optional"
    },
    "author_name": {
      "type": "string",
      "description": "Name of the article's author.",
      "x-tabstack-priority": "optional"
    },
    "author_url": {
      "type": "string",
      "description": "URL to the author's profile or bio page.",
      "x-tabstack-priority": "optional"
    },
    "publication_name": {
      "type": "string",
      "description": "Name of the publication or outlet.",
      "x-tabstack-priority": "required"
    },
    "publication_domain": {
      "type": "string",
      "description": "Domain of the publication (e.g., 'techcrunch.com').",
      "x-tabstack-priority": "optional"
    },
    "published_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime when the article was first published.",
      "x-tabstack-priority": "required"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime when the article was last updated.",
      "x-tabstack-priority": "optional"
    },
    "article_url": {
      "type": "string",
      "description": "Direct URL to the article.",
      "x-tabstack-priority": "required"
    },
    "canonical_url": {
      "type": "string",
      "description": "Canonical URL as declared by the article page.",
      "x-tabstack-priority": "optional"
    },
    "body_text": {
      "type": "string",
      "description": "Full body text of the article.",
      "x-tabstack-priority": "optional"
    },
    "summary": {
      "type": "string",
      "description": "Short summary or abstract of the article.",
      "x-tabstack-priority": "optional"
    },
    "word_count": {
      "type": "number",
      "description": "Approximate word count of the article body.",
      "x-tabstack-priority": "optional"
    },
    "language": {
      "type": "string",
      "description": "BCP-47 language code of the article (e.g., 'en').",
      "x-tabstack-priority": "optional"
    },
    "section": {
      "type": "string",
      "description": "Publication section or category the article appears in.",
      "x-tabstack-priority": "optional"
    },
    "tags": {
      "type": "array",
      "description": "List of tags or topic labels applied to the article.",
      "items": {
        "type": "string"
      },
      "x-tabstack-priority": "optional"
    },
    "entities_mentioned": {
      "type": "array",
      "description": "Named entities mentioned in the article.",
      "items": {
        "$ref": "#/$defs/EntityMention"
      },
      "x-tabstack-priority": "optional"
    },
    "sentiment": {
      "type": "string",
      "description": "Overall sentiment of the article.",
      "enum": [
        "positive",
        "negative",
        "neutral"
      ],
      "x-tabstack-priority": "optional"
    },
    "paywall": {
      "type": "boolean",
      "description": "Whether the article is behind a paywall.",
      "x-tabstack-priority": "optional"
    },
    "image_url": {
      "type": "string",
      "description": "URL to the article's featured image.",
      "x-tabstack-priority": "optional"
    },
    "source_url": {
      "type": "string",
      "description": "The URL of the page this data was sourced from.",
      "x-tabstack-priority": "required"
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this record was extracted.",
      "x-tabstack-priority": "required"
    }
  },
  "$defs": {
    "EntityMention": {
      "type": "object",
      "description": "A named entity referenced in the article.",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the entity."
        },
        "type": {
          "type": "string",
          "description": "Category of the entity.",
          "enum": [
            "company",
            "person",
            "product",
            "location",
            "other"
          ]
        },
        "url": {
          "type": "string",
          "description": "Optional URL associated with the entity."
        }
      },
      "required": [
        "name",
        "type"
      ]
    }
  },
  "required": [
    "headline",
    "publication_name",
    "published_at",
    "article_url",
    "source_url",
    "extracted_at"
  ]
}