{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.com/v1/finance/crypto-asset.json",
  "title": "Crypto Asset",
  "description": "Snapshot of market data for a cryptocurrency or digital asset.",
  "type": "object",
  "properties": {
    "token_name": {
      "type": "string",
      "description": "Full name of the token or cryptocurrency.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap",
        "exchange listing"
      ]
    },
    "token_symbol": {
      "type": "string",
      "description": "Ticker symbol of the token (e.g., BTC, ETH).",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap",
        "exchange listing"
      ]
    },
    "coingecko_id": {
      "type": "string",
      "description": "CoinGecko identifier for the asset.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko API"
      ]
    },
    "contract_address": {
      "type": "string",
      "description": "Smart contract address for the token.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "blockchain explorer",
        "CoinGecko"
      ]
    },
    "blockchain": {
      "type": "string",
      "description": "Blockchain network where the token resides.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "blockchain explorer"
      ]
    },
    "price_usd": {
      "type": "number",
      "description": "Current price in USD.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap",
        "exchange API"
      ]
    },
    "price_change_24h_pct": {
      "type": "number",
      "description": "Price change percentage over the last 24 hours.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "price_change_7d_pct": {
      "type": "number",
      "description": "Price change percentage over the last 7 days.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "market_cap_usd": {
      "type": "number",
      "description": "Market capitalization in USD.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "market_cap_rank": {
      "type": "number",
      "description": "Global market cap rank.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "volume_24h_usd": {
      "type": "number",
      "description": "24-hour trading volume in USD.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap",
        "exchange"
      ]
    },
    "circulating_supply": {
      "type": "number",
      "description": "Number of tokens currently in circulation.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "total_supply": {
      "type": "number",
      "description": "Total token supply.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "token contract"
      ]
    },
    "max_supply": {
      "type": "number",
      "description": "Maximum possible token supply.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "whitepaper"
      ]
    },
    "fully_diluted_valuation_usd": {
      "type": "number",
      "description": "Fully diluted valuation (FDV) in USD.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "ath_usd": {
      "type": "number",
      "description": "All-time high price in USD.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "ath_date": {
      "type": "string",
      "format": "date",
      "description": "Date of all-time high price.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko",
        "CoinMarketCap"
      ]
    },
    "category": {
      "type": "string",
      "description": "Asset category (e.g., DeFi, Layer 1, stablecoin).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "CoinGecko categories",
        "CoinMarketCap tags"
      ]
    },
    "snapshot_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the price snapshot.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "API response timestamp"
      ]
    },
    "source_url": {
      "type": "string",
      "description": "URL of the source page.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "CoinGecko asset page",
        "CoinMarketCap asset page"
      ]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this record was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "scraper metadata"
      ]
    }
  },
  "required": [
    "token_name",
    "token_symbol",
    "price_usd",
    "snapshot_at",
    "source_url",
    "extracted_at"
  ]
}