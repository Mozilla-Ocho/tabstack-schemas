{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.com/v1/healthcare/clinical-trial.json",
  "title": "Clinical Trial",
  "description": "Clinical trial registration and status information from ClinicalTrials.gov or equivalent registry.",
  "type": "object",
  "properties": {
    "nct_id": {
      "type": "string",
      "description": "ClinicalTrials.gov NCT identifier.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov",
        "trial registry"
      ]
    },
    "title": {
      "type": "string",
      "description": "Official title of the clinical trial.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov title field"
      ]
    },
    "sponsor_name": {
      "type": "string",
      "description": "Primary sponsor organization.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov sponsor field"
      ]
    },
    "sponsor_type": {
      "type": "string",
      "enum": [
        "industry",
        "academic",
        "nih",
        "other"
      ],
      "description": "Type of primary sponsor.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov sponsor class"
      ]
    },
    "collaborators": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of collaborating organizations.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov collaborators section"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "recruiting",
        "active_not_recruiting",
        "completed",
        "terminated",
        "withdrawn",
        "suspended"
      ],
      "description": "Current recruitment status of the trial.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov status field"
      ]
    },
    "phase": {
      "type": "string",
      "enum": [
        "1",
        "1_2",
        "2",
        "2_3",
        "3",
        "4",
        "na"
      ],
      "description": "Clinical trial phase.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov phase field"
      ]
    },
    "study_type": {
      "type": "string",
      "enum": [
        "interventional",
        "observational"
      ],
      "description": "Type of study design.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov study type field"
      ]
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Medical conditions or diseases being studied.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov conditions section"
      ]
    },
    "interventions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Intervention"
      },
      "description": "Interventions being tested.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov interventions section"
      ]
    },
    "primary_outcomes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/Outcome"
      },
      "description": "Primary outcome measures.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov outcome measures section"
      ]
    },
    "enrollment_target": {
      "type": "number",
      "description": "Target number of participants.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov enrollment field"
      ]
    },
    "enrollment_actual": {
      "type": "number",
      "description": "Actual number of participants enrolled.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov enrollment field"
      ]
    },
    "start_date": {
      "type": "string",
      "format": "date",
      "description": "Study start date.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov dates section"
      ]
    },
    "primary_completion_date": {
      "type": "string",
      "format": "date",
      "description": "Primary completion date.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov dates section"
      ]
    },
    "locations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/TrialLocation"
      },
      "description": "Study locations.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov locations section"
      ]
    },
    "eligibility_min_age": {
      "type": "string",
      "description": "Minimum age for eligibility.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov eligibility criteria"
      ]
    },
    "eligibility_max_age": {
      "type": "string",
      "description": "Maximum age for eligibility.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov eligibility criteria"
      ]
    },
    "eligibility_sex": {
      "type": "string",
      "description": "Sex eligibility requirement.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov eligibility criteria"
      ]
    },
    "results_available": {
      "type": "boolean",
      "description": "Whether results have been posted.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov results section"
      ]
    },
    "source_url": {
      "type": "string",
      "description": "URL of the source trial registry page.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "ClinicalTrials.gov trial URL"
      ]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this record was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": [
        "scraper metadata"
      ]
    }
  },
  "$defs": {
    "Intervention": {
      "type": "object",
      "description": "A drug, device, procedure, or other intervention being tested.",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of intervention (e.g., Drug, Device, Procedure)."
        },
        "name": {
          "type": "string",
          "description": "Name of the intervention."
        },
        "description": {
          "type": "string",
          "description": "Description of the intervention."
        }
      },
      "required": [
        "type",
        "name"
      ]
    },
    "Outcome": {
      "type": "object",
      "description": "An outcome measure for the trial.",
      "properties": {
        "measure": {
          "type": "string",
          "description": "Description of the outcome measure."
        },
        "timeframe": {
          "type": "string",
          "description": "Time point at which the outcome is measured."
        }
      },
      "required": [
        "measure"
      ]
    },
    "TrialLocation": {
      "type": "object",
      "description": "A facility or site participating in the clinical trial.",
      "properties": {
        "facility": {
          "type": "string",
          "description": "Name of the facility."
        },
        "city": {
          "type": "string",
          "description": "City of the facility."
        },
        "country": {
          "type": "string",
          "description": "Country of the facility."
        },
        "status": {
          "type": "string",
          "description": "Recruitment status at this location."
        }
      },
      "required": [
        "city",
        "country"
      ]
    }
  },
  "required": [
    "nct_id",
    "title",
    "sponsor_name",
    "status",
    "conditions",
    "source_url",
    "extracted_at"
  ]
}