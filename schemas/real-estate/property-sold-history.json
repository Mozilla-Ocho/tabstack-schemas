{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.io/real-estate/property-sold-history.json",
  "title": "Property Sold History",
  "description": "Schema for historical property sale transaction records.",
  "type": "object",
  "properties": {
    "address": {
      "type": "string",
      "description": "Street address of the sold property.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["sold listing page", "transaction record", "public records"]
    },
    "city": {
      "type": "string",
      "description": "City of the sold property.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["sold listing page", "property history section", "public records"]
    },
    "state": {
      "type": "string",
      "description": "State or province of the sold property.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["sold listing page", "transaction record", "public records"]
    },
    "zip_code": {
      "type": "string",
      "description": "ZIP or postal code of the sold property.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["listing address", "property details"]
    },
    "latitude": {
      "type": "number",
      "description": "Geographic latitude coordinate.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["map embed data", "JSON-LD structured data"]
    },
    "longitude": {
      "type": "number",
      "description": "Geographic longitude coordinate.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["map embed data", "JSON-LD structured data"]
    },
    "sale_price": {
      "type": "number",
      "description": "Final sale price of the property.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["sold price display", "transaction history table", "property history section"]
    },
    "sale_currency": {
      "type": "string",
      "description": "ISO 4217 currency code for the sale price.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["price display", "transaction details"]
    },
    "sale_date": {
      "type": "string",
      "format": "date",
      "description": "Date the property sale closed.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["sold date display", "transaction history table", "property history section"]
    },
    "property_type": {
      "type": "string",
      "description": "Type of property (e.g., single_family, condo).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["property details", "listing type badge", "public records"]
    },
    "bedrooms": {
      "type": "number",
      "description": "Number of bedrooms.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["property specs", "listing summary", "public records"]
    },
    "bathrooms": {
      "type": "number",
      "description": "Number of bathrooms.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["property specs", "listing summary", "public records"]
    },
    "sqft": {
      "type": "number",
      "description": "Total interior square footage.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["property specs", "listing summary", "public records"]
    },
    "price_per_sqft": {
      "type": "number",
      "description": "Sale price per square foot.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["transaction details", "property stats", "listing data"]
    },
    "prior_sale_price": {
      "type": "number",
      "description": "Price from the prior sale of this property.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["price history section", "property history table"]
    },
    "prior_sale_date": {
      "type": "string",
      "format": "date",
      "description": "Date of the prior sale.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["price history section", "property history table"]
    },
    "price_change_pct": {
      "type": "number",
      "description": "Percentage change in price from prior sale.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["price history section", "property value change indicator"]
    },
    "days_on_market": {
      "type": "number",
      "description": "Number of days the property was on the market before sale.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["transaction details", "listing history", "MLS data"]
    },
    "list_price": {
      "type": "number",
      "description": "Original listing price before sale.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["price history section", "transaction details", "listing history"]
    },
    "list_to_sale_ratio": {
      "type": "number",
      "description": "Ratio of sale price to list price.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["transaction details", "listing history stats"]
    },
    "financing_type": {
      "type": "string",
      "enum": ["conventional", "cash", "FHA", "VA"],
      "description": "Type of financing used in the transaction.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["transaction details", "deed records", "public records"]
    },
    "mls_id": {
      "type": "string",
      "description": "MLS identifier for the listing.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["listing details", "MLS data block", "transaction record"]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the page from which this record was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["browser URL bar", "canonical link tag", "og:url meta tag"]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this record was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["extraction metadata", "scraper system timestamp"]
    }
  },
  "required": ["address", "city", "state", "zip_code", "sale_price", "sale_date", "source_url", "extracted_at"]
}
