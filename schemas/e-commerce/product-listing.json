{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.io/e-commerce/product-listing.json",
  "title": "Product Listing",
  "description": "Schema for e-commerce product listings from marketplaces and direct retail sites.",
  "type": "object",
  "$defs": {
    "variant_option": {
      "type": "object",
      "description": "A product variant dimension and its value.",
      "properties": {
        "name": { "type": "string", "description": "Variant dimension name (e.g., Color, Size)." },
        "value": { "type": "string", "description": "Variant value (e.g., Red, XL)." }
      },
      "required": ["name", "value"]
    }
  },
  "properties": {
    "title": {
      "type": "string",
      "description": "Product title or name.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["product page h1", "og:title meta tag", "product card title"]
    },
    "brand": {
      "type": "string",
      "description": "Brand or manufacturer name.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["brand field in product details", "product byline", "breadcrumb"]
    },
    "asin_or_sku": {
      "type": "string",
      "description": "Platform-specific product identifier (ASIN, SKU, or product ID).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product details table", "URL parameter", "item number field"]
    },
    "platform": {
      "type": "string",
      "description": "E-commerce platform or marketplace (e.g., Amazon, Walmart, Shopify).",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["site domain", "platform branding", "page footer"]
    },
    "price": {
      "type": "number",
      "description": "Current listed price.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["price display", "product price span", "JSON-LD price field"]
    },
    "sale_price": {
      "type": "number",
      "description": "Sale or discounted price.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["sale price display", "discounted price label", "strikethrough price context"]
    },
    "currency": {
      "type": "string",
      "description": "ISO 4217 currency code.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["price currency symbol", "JSON-LD priceCurrency", "locale settings"]
    },
    "availability": {
      "type": "string",
      "enum": ["in_stock", "out_of_stock", "limited", "preorder"],
      "description": "Current availability status of the product.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["availability badge", "in stock indicator", "JSON-LD availability field"]
    },
    "condition": {
      "type": "string",
      "enum": ["new", "used", "refurbished"],
      "description": "Condition of the product.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["condition badge", "product condition field", "used/new selector"]
    },
    "variant_options": {
      "type": "array",
      "items": { "$ref": "#/$defs/variant_option" },
      "description": "Available variant options (e.g., color, size).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["variant selector buttons", "color/size options", "product options section"]
    },
    "review_count": {
      "type": "number",
      "description": "Total number of customer reviews.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["review count label", "ratings summary", "review section header"]
    },
    "review_rating": {
      "type": "number",
      "description": "Average customer review rating.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["star rating display", "average rating number", "JSON-LD ratingValue"]
    },
    "seller_name": {
      "type": "string",
      "description": "Name of the seller or vendor.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["sold by field", "seller name display", "merchant info section"]
    },
    "fulfillment_type": {
      "type": "string",
      "enum": ["FBA", "FBM", "direct"],
      "description": "Fulfillment method (Fulfilled by Amazon, Merchant, or Direct).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["fulfillment badge", "ships from label", "sold and shipped by text"]
    },
    "images": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "URLs of product images.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product image gallery", "image carousel", "og:image meta tag"]
    },
    "description": {
      "type": "string",
      "description": "Full product description text.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product description section", "about this item", "product overview"]
    },
    "features_list": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Bullet-point feature list.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["feature bullets section", "key features list", "product highlights"]
    },
    "category": {
      "type": "string",
      "description": "Primary product category.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["breadcrumb navigation", "category field", "product metadata"]
    },
    "subcategory": {
      "type": "string",
      "description": "Product subcategory.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["breadcrumb navigation", "subcategory field", "product metadata"]
    },
    "rank_in_category": {
      "type": "number",
      "description": "Bestseller or sales rank within the category.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["bestseller rank section", "category rank display", "product details"]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the product page from which this data was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["browser URL bar", "canonical link tag", "og:url meta tag"]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this product was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["extraction metadata", "scraper system timestamp"]
    }
  },
  "required": ["title", "platform", "price", "availability", "source_url", "extracted_at"]
}
