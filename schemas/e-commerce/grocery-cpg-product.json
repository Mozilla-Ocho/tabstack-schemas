{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.tabstack.io/e-commerce/grocery-cpg-product.json",
  "title": "Grocery & CPG Product",
  "description": "Schema for grocery and consumer packaged goods (CPG) product listings.",
  "type": "object",
  "properties": {
    "product_name": {
      "type": "string",
      "description": "Name of the grocery or CPG product.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["product page h1", "product card title", "og:title meta tag"]
    },
    "brand": {
      "type": "string",
      "description": "Brand name of the product.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["brand field in product details", "product byline", "package brand label"]
    },
    "upc": {
      "type": "string",
      "description": "Universal Product Code (UPC/EAN barcode).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product details table", "product ID field", "barcode data"]
    },
    "platform": {
      "type": "string",
      "description": "E-commerce platform or grocery delivery app.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["site domain", "platform branding", "app name"]
    },
    "store_name": {
      "type": "string",
      "description": "Physical or online store name.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["store name header", "retailer branding", "sold by field"]
    },
    "price": {
      "type": "number",
      "description": "Current price of the product.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["price display", "product price span", "JSON-LD price field"]
    },
    "unit_price": {
      "type": "number",
      "description": "Price per unit of measure (e.g., per oz, per count).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["unit price display", "per oz price label", "price per unit section"]
    },
    "unit_of_measure": {
      "type": "string",
      "description": "Unit of measure for unit pricing (e.g., oz, lb, count).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["unit price label", "product weight field", "package size indicator"]
    },
    "sale_price": {
      "type": "number",
      "description": "Sale or discounted price.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["sale price display", "discount label", "was/now price display"]
    },
    "availability": {
      "type": "string",
      "enum": ["in_stock", "out_of_stock", "limited"],
      "description": "Current availability status.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["availability badge", "in stock indicator", "add to cart button state"]
    },
    "category": {
      "type": "string",
      "description": "Primary product category (e.g., Dairy, Snacks, Beverages).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["breadcrumb navigation", "category field", "aisle label"]
    },
    "subcategory": {
      "type": "string",
      "description": "Product subcategory.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["breadcrumb navigation", "subcategory field", "aisle sub-label"]
    },
    "weight_oz": {
      "type": "number",
      "description": "Product weight in ounces.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product size/weight field", "package label", "product details table"]
    },
    "calories": {
      "type": "number",
      "description": "Calories per serving.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["nutrition facts label", "calories per serving display", "nutritional info section"]
    },
    "ingredients": {
      "type": "string",
      "description": "Ingredients list as a string.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["ingredients section", "product label ingredients", "nutrition tab"]
    },
    "allergens": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of allergens present or may contain.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["allergen section", "contains/may contain labels", "product warning section"]
    },
    "nutritional_info": {
      "type": "object",
      "description": "Key nutritional values per serving.",
      "properties": {
        "fat": { "type": "number", "description": "Total fat in grams." },
        "carbs": { "type": "number", "description": "Total carbohydrates in grams." },
        "protein": { "type": "number", "description": "Protein in grams." },
        "sodium": { "type": "number", "description": "Sodium in milligrams." },
        "sugar": { "type": "number", "description": "Total sugars in grams." },
        "fiber": { "type": "number", "description": "Dietary fiber in grams." }
      },
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["nutrition facts panel", "nutritional information section", "nutrition tab"]
    },
    "certifications": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Certifications or labels (e.g., Organic, Non-GMO, Gluten-Free).",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["certification badges", "product label certifications", "filter tags"]
    },
    "images": {
      "type": "array",
      "items": { "type": "string", "format": "uri" },
      "description": "URLs of product images.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product image gallery", "image carousel", "og:image meta tag"]
    },
    "description": {
      "type": "string",
      "description": "Product description text.",
      "x-tabstack-priority": "optional",
      "x-tabstack-source-hints": ["product description section", "about this item", "product overview"]
    },
    "source_url": {
      "type": "string",
      "format": "uri",
      "description": "URL of the product page extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["browser URL bar", "canonical link tag", "og:url meta tag"]
    },
    "extracted_at": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when this product was extracted.",
      "x-tabstack-priority": "required",
      "x-tabstack-source-hints": ["extraction metadata", "scraper system timestamp"]
    }
  },
  "required": ["product_name", "platform", "price", "availability", "source_url", "extracted_at"]
}
